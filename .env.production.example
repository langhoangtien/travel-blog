# ============================================
# Production Environment Variables
# ============================================
# Copy file này thành .env.production trên VPS:
#   cp .env.production.example .env.production
# Sau đó điền giá trị thật.
# KHÔNG COMMIT FILE .env.production VÀO GIT!
# ============================================

# --- Database ---
POSTGRES_DB=reiseblog
POSTGRES_USER=reiseblog
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# DATABASE_URL được tự động tạo trong docker-compose
# Chỉ cần set nếu dùng external database:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# --- NextAuth ---
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# --- Docker Image ---
DOCKER_IMAGE=ghcr.io/your-username/reiseblog:latest

# --- AWS S3 (cho upload ảnh) ---
# Bỏ trống nếu không dùng S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=

# --- Migration ---
# Set true khi deploy lần đầu hoặc khi có schema changes
RUN_MIGRATIONS=false
